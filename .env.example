# KMA API Hub auth key. Never commit a real key.
KMA_APIHUB_AUTH_KEY=

# Optional KIM request overrides.
# Official API Hub path used by backend:
# https://apihub.kma.go.kr/api/typ06/cgi-bin/url/nph-kim_grib_pt_txt1
KMA_KIM_GROUP=KIML
KMA_KIM_NWP=l010
KMA_KIM_DATA=U
KMA_KIM_LEVEL=0
KMA_KIM_HF=0

# Variable code from KMA API Hub KIM variable reference.
# Default adapter treats the first numeric response value as temperature.
KMA_KIM_VARN=2002
